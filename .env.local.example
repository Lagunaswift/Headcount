# Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Store backend: "memory" (default, zero setup, resets on restart) or
# "firestore" (persistent). Everything below only matters for firestore.
STORE_BACKEND=memory

# --- Firestore (server-side, via firebase-admin) ----------------------------
# Authenticate with ONE of:
#   - FIREBASE_SERVICE_ACCOUNT_B64: the service-account JSON, base64-encoded, or
#   - GOOGLE_APPLICATION_CREDENTIALS: a path to that JSON file (ADC).
FIREBASE_SERVICE_ACCOUNT_B64=
# Project id. Read from the service-account JSON automatically; set explicitly
# when using ADC or the emulator.
FIREBASE_PROJECT_ID=

# Local emulator (optional): point the Admin SDK at a local Firestore so you can
# run STORE_BACKEND=firestore with no real project or credentials. Set
# FIREBASE_PROJECT_ID to anything (e.g. demo-agentic) when using this.
#   FIRESTORE_EMULATOR_HOST=127.0.0.1:8080

# --- Firebase client SDK ----------------------------------------------------
# NOT used by the server-side store; reserved for future browser features.
# Safe to leave blank.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
