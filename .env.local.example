# Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Firebase (client) — from your Firebase project settings
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin (server) — service account JSON, base64-encoded, OR use
# GOOGLE_APPLICATION_CREDENTIALS pointing at the file in local dev.
FIREBASE_SERVICE_ACCOUNT_B64=

# Set to "memory" to run with the in-memory store (no Firestore needed),
# or "firestore" once your credentials above are filled in.
STORE_BACKEND=memory
